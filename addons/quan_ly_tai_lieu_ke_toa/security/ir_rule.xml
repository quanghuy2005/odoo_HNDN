<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- RULE 1: Người dùng chỉ xem tài liệu của khách hàng phụ trách -->
        <record id="rule_tai_lieu_khach_hang" model="ir.rule">
            <field name="name">Tài Liệu - Khách Hàng Phụ Trách</field>
            <field name="model_id" ref="model_tai_lieu_ke_toa"/>
            <field name="domain_force">
                [
                    '|',
                    '|',
                    ('khach_hang.user_id', '=', user.id),
                    ('nhan_vien_phu_trach.user_id', '=', user.id),
                    ('create_uid', '=', user.id)
                ]
            </field>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">False</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- RULE 2: Admin Tài Liệu xem tất cả -->
        <record id="rule_tai_lieu_admin" model="ir.rule">
            <field name="name">Tài Liệu - Admin Xem Tất Cả</field>
            <field name="model_id" ref="model_tai_lieu_ke_toa"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
            <field name="groups" eval="[(4, ref('quan_ly_tai_lieu_ke_toa.group_quan_ly_tai_lieu_admin'))]"/>
        </record>

        <!-- RULE 3: HR Manager full access -->
        <record id="rule_tai_lieu_hr_manager" model="ir.rule">
            <field name="name">Tài Liệu - HR Manager Full Access</field>
            <field name="model_id" ref="model_tai_lieu_ke_toa"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
            <field name="groups" eval="[(4, ref('hr.group_hr_manager'))]"/>
        </record>

        <!-- RULE 4: Phiếu Phê Duyệt - Người dùng chỉ xem phiếu của tài liệu họ có quyền xem -->
        <record id="rule_phieu_phe_duyet" model="ir.rule">
            <field name="name">Phiếu Phê Duyệt - Quyền Xem Tương Ứng</field>
            <field name="model_id" ref="model_phieu_phe_duyet"/>
            <field name="domain_force">
                [
                    '|',
                    '|',
                    ('tai_lieu.khach_hang.user_id', '=', user.id),
                    ('tai_lieu.nhan_vien_phu_trach.user_id', '=', user.id),
                    ('tai_lieu.create_uid', '=', user.id)
                ]
            </field>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">False</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- RULE 4b: Phiếu Phê Duyệt - Admin xem tất cả -->
        <record id="rule_phieu_phe_duyet_admin" model="ir.rule">
            <field name="name">Phiếu Phê Duyệt - Admin Xem Tất Cả</field>
            <field name="model_id" ref="model_phieu_phe_duyet"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
            <field name="groups" eval="[(4, ref('quan_ly_tai_lieu_ke_toa.group_quan_ly_tai_lieu_admin'))]"/>
        </record>

        <!-- RULE 4c: Phiếu Phê Duyệt - HR Manager full access -->
        <record id="rule_phieu_phe_duyet_hr_manager" model="ir.rule">
            <field name="name">Phiếu Phê Duyệt - HR Manager Full Access</field>
            <field name="model_id" ref="model_phieu_phe_duyet"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
            <field name="groups" eval="[(4, ref('hr.group_hr_manager'))]"/>
        </record>

        <!-- RULE 5: File Đính Kèm - Tương tự tài liệu -->
        <record id="rule_dinh_kem_file" model="ir.rule">
            <field name="name">File Đính Kèm - Quyền Xem Tương Ứng</field>
            <field name="model_id" ref="model_dinh_kem_file"/>
            <field name="domain_force">
                [
                    '|',
                    '|',
                    ('tai_lieu.khach_hang.user_id', '=', user.id),
                    ('tai_lieu.nhan_vien_phu_trach.user_id', '=', user.id),
                    ('tai_lieu.create_uid', '=', user.id)
                ]
            </field>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- RULE 5b: File Đính Kèm - Admin xem tất cả -->
        <record id="rule_dinh_kem_file_admin" model="ir.rule">
            <field name="name">File Đính Kèm - Admin Xem Tất Cả</field>
            <field name="model_id" ref="model_dinh_kem_file"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
            <field name="groups" eval="[(4, ref('quan_ly_tai_lieu_ke_toa.group_quan_ly_tai_lieu_admin'))]"/>
        </record>

        <!-- RULE 5c: File Đính Kèm - HR Manager full access -->
        <record id="rule_dinh_kem_file_hr_manager" model="ir.rule">
            <field name="name">File Đính Kèm - HR Manager Full Access</field>
            <field name="model_id" ref="model_dinh_kem_file"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
            <field name="groups" eval="[(4, ref('hr.group_hr_manager'))]"/>
        </record>

        <!-- RULE 6: Tài Liệu - Portal Users chỉ xem tài liệu của công ty/khách hàng của mình -->
        <record id="rule_tai_lieu_portal" model="ir.rule">
            <field name="name">Tài Liệu - Portal Xem Tài Liệu Của Mình</field>
            <field name="model_id" ref="model_tai_lieu_ke_toa"/>
            <field name="domain_force">
                [
                    '|',
                    ('khach_hang', '=', user.partner_id.commercial_partner_id.id),
                    ('khach_hang', 'child_of', user.partner_id.commercial_partner_id.id)
                ]
            </field>
            <field name="perm_read">True</field>
            <field name="perm_write">False</field>
            <field name="perm_create">False</field>
            <field name="perm_unlink">False</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        </record>

        <!-- RULE 7: File Đính Kèm - Portal Users chỉ xem file của tài liệu họ có quyền xem -->
        <record id="rule_dinh_kem_file_portal" model="ir.rule">
            <field name="name">File Đính Kèm - Portal Xem File Của Mình</field>
            <field name="model_id" ref="model_dinh_kem_file"/>
            <field name="domain_force">
                [
                    '|',
                    ('tai_lieu.khach_hang', '=', user.partner_id.commercial_partner_id.id),
                    ('tai_lieu.khach_hang', 'child_of', user.partner_id.commercial_partner_id.id)
                ]
            </field>
            <field name="perm_read">True</field>
            <field name="perm_write">False</field>
            <field name="perm_create">False</field>
            <field name="perm_unlink">False</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        </record>

        <!-- RULE 8: Phiếu Phê Duyệt - Portal Users chỉ xem phiếu của tài liệu họ có quyền xem -->
        <record id="rule_phieu_phe_duyet_portal" model="ir.rule">
            <field name="name">Phiếu Phê Duyệt - Portal Xem Phiếu Của Mình</field>
            <field name="model_id" ref="model_phieu_phe_duyet"/>
            <field name="domain_force">
                [
                    '|',
                    ('tai_lieu.khach_hang', '=', user.partner_id.commercial_partner_id.id),
                    ('tai_lieu.khach_hang', 'child_of', user.partner_id.commercial_partner_id.id)
                ]
            </field>
            <field name="perm_read">True</field>
            <field name="perm_write">False</field>
            <field name="perm_create">False</field>
            <field name="perm_unlink">False</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        </record>

    </data>
</odoo>