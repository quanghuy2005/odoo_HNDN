<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- MỞ RỘNG FORM NHÂN VIÊN - THÊM TAB TÀI LIỆU -->
        <record id="view_nhan_vien_form_tai_lieu" model="ir.ui.view">
            <field name="name">hr.employee.form.tai_lieu</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='public']" position="inside">
                    <group name="kpi_thong_ke" string="Chỉ Tiêu KPI Đạt Được (Cá Nhân)">
                        <group>
                            <field name="so_hop_dong_chot" string="Số Hợp Đồng Đã Chốt" widget="statinfo"/>
                            <field name="tong_doanh_thu_mang_ve" string="Tổng Doanh Thu Mang Về (VNĐ)" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        </group>
                    </group>
                    <group name="tai_lieu" string="Tài Liệu Phụ Trách">
                        <field name="so_tai_lieu" widget="statinfo" string="Tổng Số Tài Liệu Đang Xử Lý"/>
                        <field name="danh_sach_tai_lieu" nolabel="1" colspan="2">
                            <tree>
                                <field name="ma_tai_lieu"/>
                                <field name="ten_tai_lieu"/>
                                <field name="loai_tai_lieu"/>
                                <field name="trang_thai" widget="badge"/>
                                <field name="gia_tri_tai_lieu"/>
                            </tree>
                        </field>
                    </group>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
