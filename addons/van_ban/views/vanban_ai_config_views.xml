<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vanban_ai_config_form" model="ir.ui.view">
        <field name="name">vanban.ai.config.form</field>
        <field name="model">vanban.ai.config</field>
        <field name="arch" type="xml">
            <form string="Cấu hình AI">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="api_key" password="True"/>
                            <field name="is_active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_vanban_ai_config_tree" model="ir.ui.view">
        <field name="name">vanban.ai.config.tree</field>
        <field name="model">vanban.ai.config</field>
        <field name="arch" type="xml">
            <tree string="Cấu hình AI">
                <field name="name"/>
                <field name="is_active"/>
            </tree>
        </field>
    </record>

    <record id="action_vanban_ai_config" model="ir.actions.act_window">
        <field name="name">Cấu Hình AI Văn Bản</field>
        <field name="res_model">vanban.ai.config</field>
        <field name="view_mode">tree,form</field>
    </record>
    
    <menuitem id="menu_vanban_ai_config"
              name="AI API Key"
              parent="menu_danh_muc"
              action="action_vanban_ai_config"
              sequence="50"/>
</odoo>
