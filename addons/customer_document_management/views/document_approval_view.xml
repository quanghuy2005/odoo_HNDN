<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_document_approval_form" model="ir.ui.view">
            <field name="name">document.approval.form</field>
            <field name="model">document.approval</field>
            <field name="arch" type="xml">
                <form string="Document Approval">
                    <group>
                        <group>
                            <field name="document_id"/>
                            <field name="approver_id"/>
                            <field name="state" widget="statusbar"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="approval_date" readonly="1"/>
                        </group>
                    </group>
                    <field name="comment" nolabel="1" colspan="2"/>
                    <footer>
                        <button name="action_approve" string="Approve" type="object" class="btn-primary" 
                            states="pending"/>
                        <button name="action_reject" string="Reject" type="object" 
                            states="pending"/>
                        <button name="action_skip" string="Skip" type="object" 
                            states="pending"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="view_document_approval_list" model="ir.ui.view">
            <field name="name">document.approval.list</field>
            <field name="model">document.approval</field>
            <field name="arch" type="xml">
                <tree string="Approvals" decoration-info="state=='pending'" 
                    decoration-success="state=='approved'" decoration-danger="state=='rejected'">
                    <field name="document_id"/>
                    <field name="approver_id"/>
                    <field name="state"/>
                    <field name="approval_date"/>
                    <field name="sequence"/>
                </tree>
            </field>
        </record>

        <record id="action_document_approval" model="ir.actions.act_window">
            <field name="name">Approvals</field>
            <field name="res_model">document.approval</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem id="menu_document_approval" name="Approvals" 
            parent="menu_customer_document_root" action="action_document_approval" sequence="2"/>
    </data>
</odoo>
