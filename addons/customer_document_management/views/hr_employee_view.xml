<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Thêm field vào HR Employee Form -->
        <record id="view_hr_employee_customer_document" model="ir.ui.view">
            <field name="name">hr.employee.customer.document</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="Customer Documents" groups="sales_team.group_sale_user">
                        <group>
                            <field name="customer_ids" nolabel="1" colspan="2" widget="many2many_tags"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
