<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Thêm 2 nút bấm lên Menu trang chủ (Home Portal) -->
        <template id="portal_my_home_menu_khach_hang" name="Show Customer Documents" inherit_id="portal.portal_my_home" priority="40">
            <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
                <t t-call="portal.portal_docs_entry">
                    <t t-set="title">Hợp Đồng Mua Bán</t>
                    <t t-set="url" t-value="'/my/hop_dong'"/>
                    <t t-set="placeholder_count" t-value="'hop_dong_count'"/>
                </t>
                <t t-call="portal.portal_docs_entry">
                    <t t-set="title">Hồ Sơ Hành Chính</t>
                    <t t-set="url" t-value="'/my/ho_so'"/>
                    <t t-set="placeholder_count" t-value="'ho_so_count'"/>
                </t>
            </xpath>
        </template>

        <!-- Đường dẫn Breadcrumb Menu -->
        <template id="portal_my_home_menu_breadcrumbs" name="Portal layout : customer docs entries" inherit_id="portal.portal_breadcrumbs" priority="40">
            <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
                <li t-if="page_name == 'hop_dong' or hop_dong" t-attf-class="breadcrumb-item #{'active ' if not hop_dong else ''}">
                    <a t-if="hop_dong" t-attf-href="/my/hop_dong?{{ keep_query() }}">Hợp Đồng</a>
                    <t t-else="">Hợp Đồng Của Tôi</t>
                </li>
                <li t-if="page_name == 'ho_so_van_ban' or ho_so_van_ban" t-attf-class="breadcrumb-item #{'active ' if not ho_so_van_ban else ''}">
                    <a t-if="ho_so_van_ban" t-attf-href="/my/ho_so?{{ keep_query() }}">Hồ Sơ Hành Chính</a>
                    <t t-else="">Hồ Sơ Số của Tôi</t>
                </li>
            </xpath>
        </template>
        
        <!-- Bảng danh sách Hợp Đồng Kế Toán -->
        <template id="portal_my_hop_dong_list" name="Hợp Đồng Của Tôi">
            <t t-call="portal.portal_layout">
                <t t-set="breadcrumbs_searchbar" t-value="True"/>

                <t t-call="portal.portal_searchbar">
                    <t t-set="title">Hợp Đồng Kế Toán</t>
                </t>
                <div t-if="not hop_dongs" class="alert alert-info mt-3">
                    Không có Hợp Đồng Kế Toán nào được tìm thấy cho công ty của bạn.
                </div>
                <t t-if="hop_dongs" t-call="portal.portal_table">
                    <thead>
                        <tr class="active">
                            <th>Tiêu đề</th>
                            <th>Trạng Thái</th>
                            <th>Ngày Ký</th>
                            <th>Tải Xuống</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="hop_dongs" t-as="doc">
                            <tr>
                                <td>
                                    <a t-attf-href="/my/hop_dong/ky/#{doc.id}">
                                        <span t-field="doc.ten_tai_lieu"/>
                                    </a>
                                </td>
                                <td>
                                    <span class="badge badge-pill badge-info" t-field="doc.trang_thai"/>
                                </td>
                                <td>
                                    <span t-field="doc.ngay_hieu_luc"/>
                                </td>
                                <td>
                                    <t t-if="doc.file_dinh_kem_chinh_id">
                                        <a t-attf-href="/web/content/dinh_kem.file/#{doc.file_dinh_kem_chinh_id.id}/file_noi_dung/#{doc.file_dinh_kem_chinh_id.ten_file}?download=true" target="_blank" class="btn btn-sm btn-primary mb-1">
                                            <i class="fa fa-download"/> Tải về
                                        </a>
                                        <br/>
                                        <!-- Nút Cập Nhật Trạng Thái -->
                                        <a t-attf-href="/my/hop_dong/ky/#{doc.id}" class="btn btn-sm btn-info mb-1">
                                            <i class="fa fa-eye"/> Xem Chi Tiết
                                        </a>
                                        <t t-if="doc.chu_ky_khach_hang">
                                            <div class="text-success mt-1"><b><i class="fa fa-check-circle"/> Đã Ký</b></div>
                                        </t>
                                        <t t-elif="doc.trang_thai not in ['hoan_tat', 'het_han', 'huy']">
                                            <div class="mt-1">
                                                <a t-attf-href="/my/hop_dong/ky/#{doc.id}" class="btn btn-sm btn-success">
                                                    <i class="fa fa-pencil"/> Ký Xác Nhận
                                                </a>
                                            </div>
                                        </t>
                                    </t>
                                    <t t-else="">
                                        <span class="text-muted">Chưa có File</span>
                                    </t>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </t>
            </t>
        </template>

        <!-- MÀN HÌNH VẼ CHỮ KÝ CHI TIẾT (PHASE 4) -->
        <template id="portal_my_hop_dong_ky" name="Ký Hợp Đồng">
            <t t-call="portal.portal_layout">
                <div id="wrap">
                    <div class="container mt-4 mb-5">
                        <div class="card">
                            <div class="card-header bg-primary text-white">
                                <h3><i class="fa fa-pencil-square-o"/> KÝ NHẬN HỢP ĐỒNG ĐIỆN TỬ</h3>
                            </div>
                            <div class="card-body">
                                <h4>Thông tin Hợp Đồng</h4>
                                <table class="table table-bordered">
                                    <tr>
                                        <th width="30%">Mã Hợp Đồng:</th>
                                        <td><span t-field="hop_dong.ma_tai_lieu"/></td>
                                    </tr>
                                    <tr>
                                        <th>Tên Hợp Đồng:</th>
                                        <td><span t-field="hop_dong.ten_tai_lieu"/></td>
                                    </tr>
                                    <tr>
                                        <th>Giá Trị Thỏa Thuận:</th>
                                        <td class="text-danger font-weight-bold">
                                            <span t-field="hop_dong.gia_tri_tai_lieu" t-options='{"widget": "monetary", "display_currency": request.env.company.currency_id}'/>
                                        </td>
                                    </tr>
                                </table>

                                <div class="alert alert-warning mt-4">
                                    <i class="fa fa-info-circle"/> Bằng việc ký vào khung dưới đây, bạn xác nhận đồng ý với các điều khoản trong văn bản. Chữ ký số có giá trị pháp lý tương đương chữ ký tươi.
                                </div>

                                <!-- HIỂN THỊ CHỮ KÝ ĐẠI DIỆN 2 BÊN -->
                                <div class="row mt-4 text-center">
                                    <div class="col-6" style="border-right: 2px dashed #ccc;">
                                        <h5 class="text-primary">ĐẠI DIỆN CÔNG TY BÁN</h5>
                                        <t t-if="hop_dong.chu_ky_nguoi_duyet">
                                            <div class="mt-3">
                                                <span t-field="hop_dong.chu_ky_nguoi_duyet" t-options="{'widget': 'image', 'style': 'max-height: 100px; padding-bottom: 5px; border-bottom: 1px solid #000;'}"/>
                                            </div>
                                            <p class="mt-2 text-muted">Ký bởi: <b t-field="hop_dong.ky_boi.name"/></p>
                                        </t>
                                        <t t-else="">
                                            <div class="mt-4 mb-4 text-muted border p-3 bg-light">
                                                <i>(Chưa ký duyệt)</i>
                                            </div>
                                        </t>
                                    </div>
                                    <div class="col-6">
                                        <h5 class="text-success">ĐẠI DIỆN KHÁCH HÀNG</h5>
                                        <t t-if="hop_dong.chu_ky_khach_hang">
                                            <div class="mt-3">
                                                <span t-field="hop_dong.chu_ky_khach_hang" t-options="{'widget': 'image', 'style': 'max-height: 100px; padding-bottom: 5px; border-bottom: 1px solid #000;'}"/>
                                            </div>
                                            <p class="mt-2 text-muted">Ký xác nhận: <b t-field="hop_dong.khach_hang.name"/></p>
                                        </t>
                                        <t t-else="">
                                            <div class="mt-4 mb-4 text-muted border p-3 bg-light">
                                                <i>(Đang chờ ký xác nhận)</i>
                                            </div>
                                        </t>
                                    </div>
                                </div>

                                <!-- KHU VỰC DRAWING CANVAS (CHỈ HIỆN KHI KHÁCH CHƯA KÝ) -->
                                <t t-if="not hop_dong.chu_ky_khach_hang">
                                    <div class="text-center mt-4 border-top pt-4">
                                        <h5>XIN MỜI KÝ VÀO KHUNG DƯỚI ĐÂY:</h5>
                                        <div style="border: 2px dashed #007bff; background: #f8f9fa; display: inline-block; padding: 10px; border-radius: 10px;">
                                            <canvas id="signature-pad" width="600" height="250" style="background: white; border: 1px solid #ccc; cursor: crosshair; touch-action: none;"></canvas>
                                        </div>
                                        <div class="mt-3">
                                            <button type="button" class="btn btn-secondary" id="clear-btn"><i class="fa fa-eraser"/> Xóa Ký Lại</button>
                                            <button type="button" class="btn btn-success" id="save-btn" t-att-data-doc-id="hop_dong.id"><i class="fa fa-paper-plane"/> Gửi Chữ Ký Xác Nhận</button>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>

                        <!-- CHATTER / LỊCH SỬ TRAO ĐỔI -->
                        <div class="row mt-4 mb-4" id="hop_dong_communication">
                            <div class="col-12">
                                <h3>Lịch Sử Trao Đổi &amp; Email</h3>
                                <t t-call="portal.message_thread">
                                    <t t-set="object" t-value="hop_dong"/>
                                </t>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- JAVASCRIPT XỬ LÝ VẼ LOGIC -->
                <script type="text/javascript">
                    function initSignature() {
                        var canvas = document.getElementById('signature-pad');
                        if (!canvas) return; // Nếu chưa thấy canvas thì bỏ qua
                        if (canvas.getAttribute('data-init')) return; // Chống lặp
                        canvas.setAttribute('data-init', '1');

                        var ctx = canvas.getContext('2d');
                        var drawing = false;

                        function getPos(e) {
                            var rect = canvas.getBoundingClientRect();
                            var x, y;
                            if (e.type.indexOf('touch') !== -1) {
                                x = e.touches[0].clientX;
                                y = e.touches[0].clientY;
                            } else {
                                x = e.clientX;
                                y = e.clientY;
                            }
                            return { x: x - rect.left, y: y - rect.top };
                        }

                        var startDrawing = function(e) {
                            drawing = true;
                            var pos = getPos(e);
                            ctx.beginPath();
                            ctx.moveTo(pos.x, pos.y);
                            e.preventDefault();
                        };

                        var draw = function(e) {
                            if (!drawing) return;
                            var pos = getPos(e);
                            ctx.lineTo(pos.x, pos.y);
                            ctx.strokeStyle = '#000080';
                            ctx.lineWidth = 3;
                            ctx.lineCap = 'round';
                            ctx.lineJoin = 'round';
                            ctx.stroke();
                            e.preventDefault();
                        };

                        var stopDrawing = function(e) {
                            drawing = false;
                            e.preventDefault();
                        };

                        canvas.addEventListener('mousedown', startDrawing);
                        canvas.addEventListener('mousemove', draw);
                        canvas.addEventListener('mouseup', stopDrawing);
                        canvas.addEventListener('mouseout', stopDrawing);
                        canvas.addEventListener('touchstart', startDrawing, {passive: false});
                        canvas.addEventListener('touchmove', draw, {passive: false});
                        canvas.addEventListener('touchend', stopDrawing, {passive: false});

                        var clearBtn = document.getElementById('clear-btn');
                        if (clearBtn) {
                            clearBtn.addEventListener('click', function() {
                                ctx.clearRect(0, 0, canvas.width, canvas.height);
                            });
                        }

                        var saveBtn = document.getElementById('save-btn');
                        if (saveBtn) {
                            saveBtn.addEventListener('click', function() {
                                var blank = document.createElement('canvas');
                                blank.width = canvas.width;
                                blank.height = canvas.height;
                                if (canvas.toDataURL() === blank.toDataURL()) {
                                    alert("Oops! Bạn chưa ký vào khung trắng. Vui lòng di chuột vẽ chữ ký trước nhé!");
                                    return;
                                }

                                saveBtn.innerHTML = "Đang xử lý...";
                                saveBtn.disabled = true;

                                var dataURL = canvas.toDataURL("image/png");
                                var doc_id = saveBtn.getAttribute('data-doc-id');

                                fetch('/my/hop_dong/luu_chu_ky', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({
                                        jsonrpc: "2.0",
                                        method: "call",
                                        params: { doc_id: parseInt(doc_id), signature: dataURL }
                                    })
                                })
                                .then(function(res) { return res.json(); })
                                .then(function(data) {
                                    var result = data.result;
                                    if (result &amp;&amp; result.error) {
                                        alert("LỖI ODOO: " + result.error);
                                        window.location.reload();
                                    } else {
                                        alert("Chúc mừng! Bạn đã ký hợp đồng thành công.");
                                        window.location.href = '/my/hop_dong';
                                    }
                                })
                                .catch(function() {
                                    alert("Lỗi kết nối mạng, vui lòng thử lại.");
                                    saveBtn.innerHTML = "Gửi Chữ Ký Xác Nhận";
                                    saveBtn.disabled = false;
                                });
                            });
                        }
                        console.log("Canvas Signature Initialized Successfully!");
                    }

                    // Ép hệ thống nạp Javascript bằng 3 cách để không thể xịt!
                    initSignature(); 
                    document.addEventListener("DOMContentLoaded", initSignature);
                    setTimeout(initSignature, 500);
                    setTimeout(initSignature, 1500);
                </script>
            </t>
        </template>

        <!-- Bảng danh sách Hồ Sơ Hành Chính (Văn Bản) -->
        <template id="portal_my_ho_so_list" name="Hồ Sơ Của Tôi">
            <t t-call="portal.portal_layout">
                <t t-set="breadcrumbs_searchbar" t-value="True"/>

                <t t-call="portal.portal_searchbar">
                    <t t-set="title">Hồ Sơ Văn Bản Hành Chính</t>
                </t>
                <div t-if="not ho_sos" class="alert alert-warning mt-3">
                    Hiện chưa có Hồ sơ Giấy phép / Văn bản pháp lý nào nằm trong tủ của bạn.
                </div>
                <t t-if="ho_sos" t-call="portal.portal_table">
                    <thead>
                        <tr class="active">
                            <th>Mã Hồ Sơ</th>
                            <th>Tên Hồ Sơ</th>
                            <th>Loại V.Bản</th>
                            <th>Trạng Thái</th>
                            <th>Tệp Đính Kèm</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="ho_sos" t-as="hs">
                            <tr>
                                <td><span t-field="hs.ma_ho_so"/></td>
                                <td><span t-field="hs.ten_ho_so"/></td>
                                <td><span t-field="hs.loai_ho_so"/></td>
                                <td><span class="badge badge-pill badge-success" t-field="hs.trang_thai"/></td>
                                <td>
                                    <t t-if="hs.file_dinh_kem">
                                        <a t-attf-href="/web/content/ho_so_van_ban/#{hs.id}/file_dinh_kem/#{hs.file_name}?download=true" target="_blank" class="btn btn-sm btn-success">
                                            <i class="fa fa-download"/> Nhận Bản Sao File
                                        </a>
                                    </t>
                                    <t t-else="">
                                        <span class="text-muted">Đang cập nhật</span>
                                    </t>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </t>
            </t>
        </template>
    </data>
</odoo>
