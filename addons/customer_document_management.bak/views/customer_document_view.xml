<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Menu Items -->
        <menuitem id="menu_customer_document_root" name="Document Management" 
            sequence="100"/>
        
        <menuitem id="menu_documents" name="Documents" 
            parent="menu_customer_document_root" sequence="1"/>

        <!-- List View -->
        <record id="view_customer_document_list" model="ir.ui.view">
            <field name="name">customer.document.list</field>
            <field name="model">customer.document</field>
            <field name="arch" type="xml">
                <tree string="Documents" decoration-info="state=='draft'" 
                    decoration-warning="state=='under_review'" 
                    decoration-success="state=='signed'">
                    <field name="reference"/>
                    <field name="name"/>
                    <field name="partner_id"/>
                    <field name="document_type"/>
                    <field name="state"/>
                    <field name="issue_date"/>
                    <field name="expiry_date"/>
                    <field name="employee_id"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_customer_document_form" model="ir.ui.view">
            <field name="name">customer.document.form</field>
            <field name="model">customer.document</field>
            <field name="arch" type="xml">
                <form string="Customer Document">
                    <header>
                        <button name="action_submit" string="Submit" type="object" 
                            class="oe_highlight" states="draft"/>
                        <button name="action_request_approval" string="Request Approval" type="object" 
                            class="oe_highlight" states="submitted"/>
                        <button name="action_approve" string="Approve" type="object" 
                            class="oe_highlight" states="under_review,submitted"/>
                        <button name="action_sign" string="Sign" type="object" 
                            class="oe_highlight" states="approved"/>
                        <button name="action_complete" string="Complete" type="object" 
                            states="signed"/>
                        <button name="action_create_new_version" string="Create New Version" type="object" 
                            states="completed,signed"/>
                        <button name="action_send_to_customer" string="Send to Customer" type="object" 
                            states="approved,signed,completed"/>
                        <button name="action_cancel" string="Cancel" type="object" 
                            class="oe_link" states="draft,submitted"/>
                        <field name="state" widget="statusbar" 
                            statusbar_visible="draft,submitted,under_review,approved,signed,completed"/>
                    </header>
                    
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" type="object" name="action_view_attachments">
                                <field string="Attachments" name="attachment_count" widget="statinfo"/>
                            </button>
                            <button class="oe_stat_button" type="object" name="action_view_approvals">
                                <field string="Approvals" name="approval_count" widget="statinfo"/>
                            </button>
                        </div>

                        <div class="oe_title">
                            <h1>
                                <field name="reference" readonly="1"/>
                            </h1>
                        </div>

                        <group>
                            <group>
                                <field name="name"/>
                                <field name="document_type"/>
                                <field name="partner_id"/>
                                <field name="employee_id"/>
                            </group>
                            <group>
                                <field name="issue_date"/>
                                <field name="effective_date"/>
                                <field name="expiry_date"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="General Information">
                                <group>
                                    <field name="description" nolabel="1" colspan="2"/>
                                </group>
                            </page>

                            <page string="Approvals">
                                <group>
                                    <group>
                                        <field name="approval_required"/>
                                        <field name="approved_by" readonly="1"/>
                                        <field name="approval_date" readonly="1"/>
                                    </group>
                                </group>
                                <field name="approval_ids" nolabel="1">
                                    <tree editable="bottom">
                                        <field name="approver_id"/>
                                        <field name="state" readonly="1"/>
                                        <field name="comment"/>
                                        <field name="approval_date" readonly="1"/>
                                    </tree>
                                </field>
                            </page>

                            <page string="Signature">
                                <group>
                                    <group>
                                        <field name="signature_required"/>
                                        <field name="signed" readonly="1"/>
                                        <field name="signed_by" readonly="1"/>
                                        <field name="signed_date" readonly="1"/>
                                    </group>
                                </group>
                            </page>

                            <page string="Files">
                                <field name="attachment_ids" nolabel="1">
                                    <tree editable="bottom">
                                        <field name="name"/>
                                        <field name="file_type" readonly="1"/>
                                        <field name="version" readonly="1"/>
                                        <field name="is_main_file"/>
                                        <field name="uploaded_by" readonly="1"/>
                                        <field name="upload_date" readonly="1"/>
                                        <button name="button_download" type="object" icon="fa-download"/>
                                    </tree>
                                </field>
                            </page>

                            <page string="Versions">
                                <field name="version_ids" nolabel="1">
                                    <tree>
                                        <field name="reference"/>
                                        <field name="document_version"/>
                                        <field name="state"/>
                                        <field name="create_date"/>
                                    </tree>
                                </field>
                            </page>

                            <page string="Tags">
                                <field name="tag_ids" nolabel="1" widget="many2many_tags"/>
                            </page>

                            <page string="Internal Notes">
                                <field name="notes" nolabel="1" colspan="2"/>
                            </page>
                        </notebook>
                    </sheet>

                    <div class="oe_chatter">
                        <field name="message_ids" widget="mail_thread"/>
                        <field name="activity_ids" widget="mail_activity"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_customer_document_search" model="ir.ui.view">
            <field name="name">customer.document.search</field>
            <field name="model">customer.document</field>
            <field name="arch" type="xml">
                <search string="Search Documents">
                    <field name="name" string="Document Name"/>
                    <field name="reference"/>
                    <field name="partner_id"/>
                    <field name="employee_id"/>
                    <field name="document_type"/>
                    <field name="content_search" string="Full Text Search"/>
                    <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                    <filter name="filter_submitted" string="Submitted" domain="[('state', '=', 'submitted')]"/>
                    <filter name="filter_under_review" string="Under Review" domain="[('state', '=', 'under_review')]"/>
                    <filter name="filter_approved" string="Approved" domain="[('state', '=', 'approved')]"/>
                    <filter name="filter_signed" string="Signed" domain="[('state', '=', 'signed')]"/>
                    <filter name="filter_completed" string="Completed" domain="[('state', '=', 'completed')]"/>
                    <filter name="filter_expired" string="Expired" domain="[('state', '=', 'expired')]"/>
                    <separator/>
                    <filter name="filter_contract" string="Contracts" domain="[('document_type', '=', 'contract')]"/>
                    <filter name="filter_quotation" string="Quotations" domain="[('document_type', '=', 'quotation')]"/>
                    <filter name="filter_legal" string="Legal Documents" domain="[('document_type', '=', 'legal')]"/>
                    <filter name="filter_invoice" string="Invoices" domain="[('document_type', '=', 'invoice')]"/>
                    <separator/>
                    <filter name="filter_my_responsibility" string="My Responsibility" 
                        domain="[('employee_id.user_id', '=', uid)]"/>
                    <group expand="0" string="Group By">
                        <filter name="group_by_type" string="Document Type" context="{'group_by': 'document_type'}"/>
                        <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                        <filter name="group_by_partner" string="Customer" context="{'group_by': 'partner_id'}"/>
                        <filter name="group_by_employee" string="Responsible Employee" context="{'group_by': 'employee_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_customer_document" model="ir.actions.act_window">
            <field name="name">Customer Documents</field>
            <field name="res_model">customer.document</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_customer_document_search"/>
            <field name="context">{'default_document_type': 'contract'}</field>
        </record>

        <menuitem id="menu_customer_document_list" name="All Documents" 
            parent="menu_documents" action="action_customer_document" sequence="1"/>
    </data>
</odoo>
